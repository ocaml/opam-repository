opam-version: "2.0"
synopsis: "Daily notes as plain text files"
description: """
duras stores daily notes as plain text files, one file per day.
Files are stored as YYYY/MM/YYYY-MM-DD.dn in a configurable directory.
No database, no daemon, no background services. Writes are atomic.
Optional GPG encryption per note.
"""
maintainer: "Sergiy Duras <sergiy@duras.org>"
authors: ["Sergiy Duras <sergiy@duras.org>"]
license: "ISC"
homepage: "https://codeberg.org/duras/duras"
bug-reports: "https://codeberg.org/duras/duras/issues"
depends: [
  "ocaml" {>= "4.08"}
  "dune" {>= "3.0"}
]
build: [
  ["dune" "build" "-j" jobs]
]
install: [
  ["make" "install" "PREFIX=%{prefix}%"]
]
url {
  src: "https://github.com/sduras/duras/archive/refs/tags/v2.0.0.tar.gz"
  checksum: [
    "sha256=9207c87337555d74c9545820aa01de1b4161807b6b55f57fae76af44fe3ad68d"
    "sha512=c285ccf334928654529cf96bede525ce67e4bd5c993c7bae11bdf30ce77e15809866b8fa8e540e1f9a279b7a05d89a596c423552717a423fd02732757c860828"
  ]
}
