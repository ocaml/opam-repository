  "plist-xml" {>= "0.5" & with-test}
  "alcotest" {>= "1.4" & with-test}
  "ezjsonm" {>= "1.2" & with-test}
  "yojson" {>= "1.7" & with-test}
  "odoc" {with-doc}
]
