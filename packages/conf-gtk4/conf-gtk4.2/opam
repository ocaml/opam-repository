opam-version: "2.0"
synopsis: "Virtual package relying on GTK4 system installation"
description:
  "This package can only be installed if GTK 4 is installed on the system."
maintainer: "hello@chrisarmstrong.dev"
authors: ["Chris Armstrong"]
license: "LGPL-2.1-or-later WITH OCaml-LGPL-linking-exception"
homepage: "https://github.com/chris-armstrong/ocgtk"
bug-reports: "https://github.com/chris-armstrong/ocgtk/issues"
depends: [
  "conf-pkg-config" {build}
]
depexts: [
  ["libgtk-4-dev"] {os-family = "debian"}
  ["gtk4-devel"] {os-distribution = "fedora"}
  ["gtk4-devel"] {os-distribution = "rhel"}
  ["gtk4-devel"] {os-distribution = "centos"}
  ["gtk4-devel"] {os-distribution = "opensuse-leap" | os-distribution = "opensuse-tumbleweed"}
  ["gtk4"] {os-distribution = "arch"}
  ["gtk4.0-dev"] {os-distribution = "alpine"}
  ["gtk4"] {os = "macos" & os-distribution = "homebrew"}
  ["gtk4"] {os = "macos" & os-distribution = "macports"}
  ["mingw-w64-x86_64-gtk4"] {os-distribution = "msys2"}
  ["gtk4"] {os = "freebsd"}
]
build: [
  ["pkg-config" "--short-errors" "--print-errors" "gtk4"] {os != "win32" | os-distribution = "msys2"}
]
available: os != "win32" | os-distribution = "msys2"
flags: conf
