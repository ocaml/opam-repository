opam-version: "2.0"
synopsis: "Convert Unicode strings to ASCII"
description: """
Ocaml library to convert Unicode to ASCII using transliteration tables.
Similar to Python's unidecode library.
Code originally extracted from Geneweb and adapted as a standalone library.
"""
authors: ["Daniel de Rauglaudre"]
maintainer: ["Elie Canonici-Merle <elie.canonicimerle@geneanet.org>"]
license: "GPL-3.0-or-later"
homepage: "https://github.com/geneweb/unidecode"
bug-reports: "https://github.com/geneweb/unidecode/issues"
dev-repo: "git+https://github.com/geneweb/unidecode.git"
depends: [
  "dune" { >= "1.10" }
  "ocaml" { >= "4.05" }
  ]
build: [ [ "dune" "build" "-p" name "-j" jobs ] ]
url {
  src: "https://github.com/geneweb/unidecode/archive/v0.5.0.tar.gz"
  checksum: [
