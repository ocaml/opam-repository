  "mirage-crypto" {>= "2.0"}
  "mirage-crypto-ec" {>= "2.0"}
  "digestif" {>= "1.3"}
  "mirage-crypto-rng" {with-test & >= "2.0"}
  "alcotest" {with-test & >= "1.0"}
  "yojson" {with-test & >= "2.0"}
  "ohex" {with-test & >= "0.2"}
  "odoc" {with-doc}
]
