bug-reports: "https://github.com/ocaml/opam-repository/issues"
available: os = "win32"
depends: [
  "msys2" {os-distribution = "msys2"}
  "msys2-mingw32" {os-distribution = "msys2"}
  ("host-arch-x86_32" | "host-arch-x86_64")
]
conflicts: "mingw-w64-shims"
build: [
  ["i686-w64-mingw32-gcc" "--version"]
  ["sh" "./install-shim.sh" name "mingw64-i686-binutils mingw64-i686-gcc-core" bin "i686-w64-mingw32-gcc" "_shim" "cygpath" {host-arch-x86_32:installed}] {os-distribution = "cygwin"}
]
setenv: PATH += "%{_:runtime}%"
depexts: [
  ["mingw64-i686-gcc-core"] {os = "win32" & os-distribution = "cygwin"}
  ["mingw-w64-i686-gcc"] {os = "win32" & os-distribution = "msys2"}
]
