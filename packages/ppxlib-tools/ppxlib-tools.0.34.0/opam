  "dune" {>= "3.8"}
  "ocaml" {>= "4.08.0"}
  "ppxlib" {= version}
  "cmdliner" {>= "1.3.0"}
  "cinaps" {with-test & >= "v0.12.1"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
