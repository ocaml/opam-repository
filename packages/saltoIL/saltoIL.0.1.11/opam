  "ocaml" {>= "4.14.0" & < "4.15.0"}
  "ocaml-compiler-libs" {= "v0.12.4"}
  "base" {>= "v0.16" & < "v0.17"}
  "ptmap" {>= "2.0.5"}
  "ppx_deriving" {build & >= "5.2.1"}
  "odoc" {with-doc}
]
