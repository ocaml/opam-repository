  "ocaml" {>= "5.0"}
  "dune" {>= "3.11"}
  "yojson" {>= "2.0.0"}
  "alcotest" {with-test & >= "1.9.0"}
]
build: [
  ["dune" "build" "-p" name "-j" jobs]
  ["dune" "runtest" "-p" name] {with-test}
]
