depends: [
  "ocaml" {>= "4.14.1"}
  "dune" {>= "3.13" & != "3.13.0"}
  "frama-c" {>= "33~" & < "34.0~"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "--promote-install-files=false"
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
  ["dune" "install" "-p" name "--create-install-files" name]
]
